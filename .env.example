# ─────────────────────────────────────────────────────────────────────────────
# NutriFlow — environment variables
#
# Copy this file to `.env.local` and fill every required value.
# Never commit `.env.local`. Server-only vars MUST NOT be prefixed with
# NEXT_PUBLIC_ (Next.js inlines NEXT_PUBLIC_* into the client bundle).
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (client + server) ───────────────────────────────────────────────
# Public URL of your Supabase project, e.g. https://abcd1234.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key — safe to expose in the browser, governed by RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Bypasses RLS. Used by migrations, seed, and trusted server code.
# Never expose to the client. Rotate immediately if leaked.
SUPABASE_SERVICE_ROLE_KEY=

# ── Postgres connection strings ──────────────────────────────────────────────
# Both use the Supabase pooler hostname. Direct connection (db.<ref>.supabase.co)
# is no longer exposed over IPv4 on new projects, so we use:
#   * session pooler     (port 5432) — for migrations and seed
#   * transaction pooler (port 6543) — for runtime queries (Server Actions, RSC)
#
# IMPORTANT: if your DB password contains special characters (@ : / ? # & =),
# URL-encode them. Example: `@` becomes `%40`.
#
# Get the URLs from Supabase dashboard → Project Settings → Database →
# Connection string.
DATABASE_URL_DIRECT=
DATABASE_URL_POOLER=

# ── Groq (LLM provider) ──────────────────────────────────────────────────────
# Free tier API key, no credit card required. Sign up at console.groq.com.
GROQ_API_KEY=

# Primary model for fast extraction. Override only if Groq deprecates it.
GROQ_MODEL_PRIMARY=llama-3.1-8b-instant

# Fallback model for inputs that fail Zod validation against the primary.
GROQ_MODEL_FALLBACK=openai/gpt-oss-120b

# ── USDA FoodData Central ────────────────────────────────────────────────────
# Free public API key. Sign up at fdc.nal.usda.gov/api-key-signup.html.
# Used only by the seed script, not at runtime.
FDC_API_KEY=

# ── App ──────────────────────────────────────────────────────────────────────
# Absolute URL where the app is reachable. Used in auth callbacks and emails.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# `development` | `test` | `production`. Next.js sets this automatically; the
# entry here is only for tooling scripts run outside `next dev`.
NODE_ENV=development
